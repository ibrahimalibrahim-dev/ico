echo "Files in Checkmarx/Reports:"
ls -1 Checkmarx/Reports/

# Pick all PDFs matching the glob
reports=(Checkmarx/Reports/*.pdf)

# Check if any files found
if [ ${#reports[@]} -eq 0 ]; then
    echo "No PDF reports found!"
else
    echo "Matching PDF reports:"
    for f in "${reports[@]}"; do
        echo "$f"
    done
fi
