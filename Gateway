import jenkins.model.*
import com.michelin.cio.hudson.plugins.rolestrategy.*

// Output CSV paths
def globalCsv = new File("/tmp/users_vs_roles.csv")
def pipelinesCsv = new File("/tmp/users_vs_pipelines.csv")

def jenkins = Jenkins.instance
def strategy = jenkins.getAuthorizationStrategy()

if (!(strategy instanceof RoleBasedAuthorizationStrategy)) {
    println "Role-based strategy not enabled!"
    return
}

// ------------------------
// 1️⃣ Global Users vs Roles
// ------------------------

// Categories
def roleCategory = [
    "RO": ["Overall/Read"],
    "RW": ["Job/Read","Job/Build"],
    "RWX": ["Job/Configure","Job/Delete"],
    "Admin": ["Overall/Administer"]
]

def globalRoles = ["RO","RW","RWX","Admin","Disabled"]

// Collect all users from roles (legacy-safe iteration)
def allSIDs = new HashSet<String>()
strategy.getAllRoles(RoleBasedAuthorizationStrategy.GLOBAL).each { role ->
    allSIDs.addAll(strategy.getSids(RoleBasedAuthorizationStrategy.GLOBAL, role))
}

def sidsList = allSIDs.toList().sort()
def rows = []

sidsList.each { sid ->
    def row = [sid]

    // Default ticks
    def ticks = [:].withDefault { "" }
    ticks["RO"] = ""
    ticks["RW"] = ""
    ticks["RWX"] = ""
    ticks["Admin"] = ""
    ticks["Disabled"] = "✔"

    // Iterate over roles assigned to this SID
    strategy.getAllRoles(RoleBasedAuthorizationStrategy.GLOBAL).each { role ->
        if (strategy.getSids(RoleBasedAuthorizationStrategy.GLOBAL, role).contains(sid)) {
            role.getPermissions().each { p ->
                roleCategory.each { cat, permList ->
                    if (permList.contains(p.id.toString())) {
                        ticks[cat] = "✔"
                        ticks["Disabled"] = ""
                    }
                }
            }
        }
    }

    row += globalRoles.collect { ticks[it] }
    rows << row
}

// Write CSV
globalCsv.text = ([["User/Group"] + globalRoles] + rows).collect { it.join(",") }.join("\n")
println "✅ Users vs Roles CSV generated: ${globalCsv.path}"

// ------------------------
// 2️⃣ Users vs Pipelines (Project Roles)
// ------------------------

def pipelines = jenkins.getAllItems(Job.class).sort { it.fullName }
def pipelineHeader = ["User/Group"] + pipelines.collect { it.fullName }
def pipelineRows = []

def allProjectRoles = strategy.getAllRoles(RoleBasedAuthorizationStrategy.PROJECT)

sidsList.each { sid ->
    def row = [sid]

    pipelines.each { job ->
        def hasItemPerm = allProjectRoles.any { role ->
            strategy.getSids(RoleBasedAuthorizationStrategy.PROJECT, role).contains(sid) &&
            role.getPermissions().any { it.id.toString().startsWith("Item") }
        }
        row << (hasItemPerm ? "✔" : "")
    }

    pipelineRows << row
}

// Write CSV
pipelinesCsv.text = ([pipelineHeader] + pipelineRows).collect { it.join(",") }.join("\n")
println "✅ Users vs Pipelines CSV generated: ${pipelinesCsv.path}"
