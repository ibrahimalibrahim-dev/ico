#!/bin/bash

INPUT_FILE="users.json"
OUTPUT_FILE="users_roles_matrix.csv"

echo "[INFO] Starting processing..."
echo "[INFO] Input file: $INPUT_FILE"

# Check dependencies
if ! command -v jq &> /dev/null; then
    echo "[ERROR] jq is required but not installed."
    exit 1
fi

# Temp files
ROLES_FILE=$(mktemp)
MATRIX_FILE=$(mktemp)

echo "[INFO] Extracting unique roles..."

# Extract all unique roles
jq -r '.[].roles[]' "$INPUT_FILE" | sort -u > "$ROLES_FILE"

ROLE_COUNT=$(wc -l < "$ROLES_FILE")
echo "[INFO] Found $ROLE_COUNT unique roles"

echo "[INFO] Building CSV header..."

# Build header
HEADER="userId"
while read -r role; do
    HEADER+=",$role"
done < "$ROLES_FILE"

echo "$HEADER" > "$OUTPUT_FILE"

echo "[INFO] Processing users..."

USER_COUNT=$(jq length "$INPUT_FILE")
echo "[INFO] Total users: $USER_COUNT"

# Process users
jq -c '.[]' "$INPUT_FILE" | nl -w1 -s':' | while IFS=":" read -r idx user; do
    userId=$(echo "$user" | jq -r '.userId')

    echo "[INFO] Processing user $idx/$USER_COUNT: $userId"

    LINE="$userId"

    while read -r role; do
        HAS_ROLE=$(echo "$user" | jq --arg role "$role" \
            '[.roles[] == $role] | any')

        if [ "$HAS_ROLE" = "true" ]; then
            LINE+=",✔"
        else
            LINE+=","
        fi
    done < "$ROLES_FILE"

    echo "$LINE" >> "$OUTPUT_FILE"
done

echo "[INFO] Cleaning up temp files..."
rm -f "$ROLES_FILE" "$MATRIX_FILE"

echo "[SUCCESS] CSV generated: $OUTPUT_FILE"
