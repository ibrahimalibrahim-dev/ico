// unified_access_matrix.js
// Node.js script to generate unified access matrix
// Usage: node unified_access_matrix.js

const fs = require("fs");
const path = require("path");

// === INPUT FILES ===
// Nexus JSON exported from API
const nexusFile = path.join(__dirname, "nexus_users.json");
// Checkmarx JSON exported from API
const checkmarxFile = path.join(__dirname, "checkmarx_users.json");
// Jenkins known LDAP users (CSV: one username per line)
const jenkinsUsersFile = path.join(__dirname, "jenkins_users.csv");
// Jenkins pipeline permissions CSV (optional, pre-generated if available)
const jenkinsPipelinesFile = path.join(__dirname, "jenkins_pipelines.csv");

// === OUTPUT FILE ===
const outputCsv = path.join(__dirname, "unified_access_matrix.csv");

// === LOAD DATA ===
const nexusData = JSON.parse(fs.readFileSync(nexusFile));
const checkmarxData = JSON.parse(fs.readFileSync(checkmarxFile));
const jenkinsUsers = fs.readFileSync(jenkinsUsersFile, "utf-8")
    .split("\n").map(u => u.trim()).filter(Boolean);

// Load Jenkins pipelines CSV if exists
let jenkinsPipelineData = [];
let pipelineNames = [];
if (fs.existsSync(jenkinsPipelinesFile)) {
    const lines = fs.readFileSync(jenkinsPipelinesFile, "utf-8").split("\n").filter(Boolean);
    pipelineNames = lines[0].split(",").slice(1); // skip header User/Group
    jenkinsPipelineData = lines.slice(1).map(line => {
        const cols = line.split(",");
        return { user: cols[0], perms: cols.slice(1) };
    });
}

// === HELPER: get user role tick from JSON ===
function getTick(userId, rolesList) {
    const user = rolesList.find(u => u.userId === userId);
    return user ? "✔" : "Disabled";
}

// === BUILD HEADER ===
const nexusRoles = ["RO","RW","RWX","Admin"];
const checkmarxRoles = ["Admin","RO","RW"];
const jenkinsGlobalRoles = ["OverallRead","Administer"];

const header = ["User/Group"]
    .concat(nexusRoles.map(r => `Nexus ${r}`))
    .concat(checkmarxRoles.map(r => `Checkmarx ${r}`))
    .concat(jenkinsGlobalRoles.map(r => `Jenkins ${r}`))
    .concat(pipelineNames.map(p => `Jenkins ${p}`));

// === BUILD ROWS ===
const allUsersSet = new Set([
    ...nexusData.map(u => u.userId),
    ...checkmarxData.map(u => u.userName),
    ...jenkinsUsers
]);

const allUsers = Array.from(allUsersSet).sort();

const rows = allUsers.map(userId => {
    const row = [userId];

    // Nexus roles
    nexusRoles.forEach(r => {
        row.push(getTick(userId, nexusData.map(u => ({ userId: u.userId, roles: u.roles.includes(r) }))));
    });

    // Checkmarx roles
    checkmarxRoles.forEach(r => {
        row.push(getTick(userId, checkmarxData.map(u => ({ userId: u.userName, roles: u.roles.includes(r) }))));
    });

    // Jenkins global roles
    jenkinsGlobalRoles.forEach(r => {
        // If we have pipelines CSV, check if user exists there for OverallRead/Administer
        const jUser = jenkinsPipelineData.find(u => u.user === userId);
        row.push(jUser ? "✔" : "Disabled");
    });

    // Jenkins pipelines
    pipelineNames.forEach((p, idx) => {
        const jUser = jenkinsPipelineData.find(u => u.user === userId);
        if (jUser) {
            row.push(jUser.perms[idx] || "Disabled");
        } else {
            row.push("Disabled");
        }
    });

    return row;
});

// === WRITE CSV ===
const csvContent = [header.join(","), ...rows.map(r => r.join(","))].join("\n");
fs.writeFileSync(outputCsv, csvContent);
console.log(`✅ Unified access matrix CSV generated: ${outputCsv}`);
