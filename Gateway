import jenkins.model.*
import com.michelin.cio.hudson.plugins.rolestrategy.*

// Output files
def globalCsv = new File("/tmp/users_vs_roles.csv")
def pipelinesCsv = new File("/tmp/users_vs_pipelines.csv")

// Get Jenkins instance
def jenkins = Jenkins.instance
def strategy = jenkins.getAuthorizationStrategy()

if (!(strategy instanceof RoleBasedAuthorizationStrategy)) {
    println "Role-based strategy not enabled!"
    return
}

// Map roles to simplified permission columns
def roleCategory = [
    "RO": ["Read"],
    "RW": ["Job/Read", "Job/Build"],
    "RWX": ["Job/Configure", "Job/Delete"],
    "Admin": ["Overall/Administer"]
]

// ---------------------
// 1️⃣ Users vs Roles
// ---------------------
def globalRoles = ["RO","RW","RWX","Admin","Disabled"]

def allSIDs = new HashSet()
strategy.getRoleMap(RoleBasedAuthorizationStrategy.GLOBAL).getRoles().each { role ->
    allSIDs.addAll(strategy.getRoleMap(RoleBasedAuthorizationStrategy.GLOBAL).getSidsForRole(role))
}

// Convert to list and sort
def sidsList = allSIDs.toList().sort()

def header = ["User/Group"] + globalRoles
def rows = []

sidsList.each { sid ->
    def row = [sid]
    def assignedRoles = strategy.getRoleMap(RoleBasedAuthorizationStrategy.GLOBAL).getRoles().findAll { r ->
        strategy.getRoleMap(RoleBasedAuthorizationStrategy.GLOBAL).getSidsForRole(r).contains(sid)
    }

    // Map role permissions to categories
    def ticks = [:].withDefault { "" }
    ticks["RO"] = ""
    ticks["RW"] = ""
    ticks["RWX"] = ""
    ticks["Admin"] = ""
    ticks["Disabled"] = "✔" // default disabled

    assignedRoles.each { r ->
        def perms = r.getPermissions().collect { it.id.toString() }
        perms.each { p ->
            roleCategory.each { cat, permList ->
                if (permList.contains(p)) {
                    ticks[cat] = "✔"
                    ticks["Disabled"] = "" // not disabled anymore
                }
            }
        }
    }

    row += globalRoles.collect { ticks[it] }
    rows << row
}

// Write CSV
globalCsv.text = ([header] + rows).collect { it.join(",") }.join("\n")
println "✅ Users vs Roles CSV generated: ${globalCsv.path}"

// ---------------------
// 2️⃣ Users vs Pipelines
// ---------------------

def pipelines = jenkins.getAllItems(Job.class).sort { it.fullName }

def pipelineHeader = ["User/Group"] + pipelines.collect { it.fullName }
def pipelineRows = []

sidsList.each { sid ->
    def row = [sid]

    pipelines.each { job ->
        def hasItemPerm = strategy.getAllRoles(RoleBasedAuthorizationStrategy.PROJECT).values().any { r ->
            strategy.getRoleMap(RoleBasedAuthorizationStrategy.PROJECT).getSidsForRole(r).contains(sid) &&
            r.getPermissions().any { it.id.toString().startsWith("Item") } // Any Job/Item permission
        }

        row << (hasItemPerm ? "✔" : "")
    }

    pipelineRows << row
}

// Write CSV
pipelinesCsv.text = ([pipelineHeader] + pipelineRows).collect { it.join(",") }.join("\n")
println "✅ Users vs Pipelines CSV generated: ${pipelinesCsv.path}"
