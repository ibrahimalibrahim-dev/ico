pipeline {

    agent any

    environment {
        MAVEN_HOME = tool 'Maven'
        JAVA_HOME  = tool 'JDK'
        PATH = "${MAVEN_HOME}/bin:${JAVA_HOME}/bin:${env.PATH}"
        MAVEN_SETTINGS = "/path/to/es-run.xml"
    }

    triggers {
        // runs on repository change
        pollSCM('H/2 * * * *')
    }

    stages {

        stage('Checkout Source') {
            steps {
                echo "Checking out source code..."
                checkout scm
            }
        }

        stage('Detect Module Type') {
            steps {
                script {

                    def packaging = sh(
                        script: "grep -m1 '<packaging>' pom.xml | sed -e 's/<[^>]*>//g'",
                        returnStdout: true
                    ).trim()

                    echo "Detected packaging type: ${packaging}"

                    env.MODULE_TYPE = packaging
                }
            }
        }

        stage('Build Source Code') {
            steps {
                echo "Building Maven project"

                sh """
                mvn -B \
                -Dmaven.wagon.http.pool=false \
                -DoracleHome=/path/to/oracle \
                -f pom.xml \
                -s ${MAVEN_SETTINGS} \
                clean install -U
                """
            }
        }

        stage('SCA Scan (Dependency Check)') {
            steps {
                echo "Running SCA scan"

                sh """
                mvn -s ${MAVEN_SETTINGS} \
                org.owasp:dependency-check-maven:check
                """
            }
        }

        stage('SAST Scan (SonarQube)') {
            steps {
                echo "Running SAST scan"

                withSonarQubeEnv('SonarQube') {

                    sh """
                    mvn -s ${MAVEN_SETTINGS} \
                    sonar:sonar
                    """

                }
            }
        }

        stage('Publish to Nexus (Libraries Only)') {

            when {
                expression {
                    return env.MODULE_TYPE == "jar" || env.MODULE_TYPE == "pom"
                }
            }

            steps {

                echo "Publishing shared library to Nexus"

                sh """
                mvn -s ${MAVEN_SETTINGS} deploy -DskipTests
                """

            }

        }

        stage('Build Artifact (WAR Services)') {

            when {
                expression {
                    return env.MODULE_TYPE == "war"
                }
            }

            steps {

                echo "Deployable service detected"

                sh """
                mvn -s ${MAVEN_SETTINGS} package -DskipTests
                """

            }

        }

    }

    post {

        success {
            echo "PR validation pipeline completed successfully."
        }

        failure {
            echo "Pipeline failed. Merge should be blocked."
        }

    }

}
