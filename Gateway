import com.atlassian.sal.api.component.ComponentLocator
import com.atlassian.bitbucket.user.ApplicationUser
import com.atlassian.bitbucket.user.UserService
import com.atlassian.bitbucket.user.group.GroupService
import com.atlassian.bitbucket.project.ProjectService
import com.atlassian.bitbucket.repository.RepositoryService
import com.atlassian.bitbucket.permission.PermissionService
import groovy.json.JsonOutput

// === SETUP SERVICES ===
def userService = ComponentLocator.getComponent(UserService)
def groupService = ComponentLocator.getComponent(GroupService)
def projectService = ComponentLocator.getComponent(ProjectService)
def repositoryService = ComponentLocator.getComponent(RepositoryService)
def permissionService = ComponentLocator.getComponent(PermissionService)

// === STEP 1: USERS ===
def users = userService.getAllUsers().collect { u ->
    [
        name: u.name,
        displayName: u.displayName,
        email: u.emailAddress
    ]
}
println "=== USERS ==="
println JsonOutput.prettyPrint(JsonOutput.toJson(users))

// === STEP 2: GROUPS ===
def groups = groupService.getAllGroups().collect { g ->
    def members = groupService.getUsersInGroup(g.name).collect { it.name }
    [
        group: g.name,
        users: members
    ]
}
println "\n=== GROUPS ==="
println JsonOutput.prettyPrint(JsonOutput.toJson(groups))

// === STEP 3: PROJECTS ===
def projects = projectService.getAllProjects().collect { p ->
    [
        key: p.key,
        name: p.name,
        description: p.description
    ]
}
println "\n=== PROJECTS ==="
println JsonOutput.prettyPrint(JsonOutput.toJson(projects))

// === STEP 4: REPOSITORIES ===
def repos = []
projectService.getAllProjects().each { p ->
    repositoryService.findByProject(p).each { r ->
        repos << [
            project: p.key,
            repo: r.slug,
            name: r.name,
            repoObj: r  // keep repo object for permissions
        ]
    }
}
println "\n=== REPOSITORIES ==="
println JsonOutput.prettyPrint(JsonOutput.toJson(repos.collect { [project: it.project, repo: it.repo, name: it.name] }))

// === STEP 5: PERMISSIONS ===
def matrix = []

repos.each { r ->
    // USER PERMISSIONS
    users.each { uMap ->
        def u = userService.getUserByName(uMap.name)
        def perm = permissionService.getRepositoryPermission(u, r.repoObj)
        if (perm) {
            matrix << [
                type: "user",
                name: u.name,
                project: r.project,
                repo: r.name,
                permission: perm.name()
            ]
        }
    }

    // GROUP PERMISSIONS
    groups.each { gMap ->
        def gName = gMap.group
        def perm = permissionService.getRepositoryPermission(gName, r.repoObj)
        if (perm) {
            matrix << [
                type: "group",
                name: gName,
                project: r.project,
                repo: r.name,
                permission: perm.name()
            ]
        }
    }
}

println "\n=== PERMISSIONS MATRIX ==="
println JsonOutput.prettyPrint(JsonOutput.toJson(matrix))
