import com.atlassian.bitbucket.user.ApplicationUser
import com.atlassian.bitbucket.repository.RepositoryService
import com.atlassian.bitbucket.permission.PermissionService
import com.atlassian.bitbucket.project.ProjectService

def users = userService.getAllUsers()
def projects = projectService.getAllProjects()

def matrix = []

projects.each { project ->
    project.repositories.each { repo ->
        users.each { user ->
            def perm = permissionService.getRepositoryPermission(user, repo)
            if (perm) {
                matrix << [
                    user: user.getName(),
                    project: project.key,
                    repo: repo.name,
                    permission: perm.name()
                ]
            }
        }
    }
}

// Convert matrix to JSON or CSV
println groovy.json.JsonOutput.prettyPrint(groovy.json.JsonOutput.toJson(matrix))
