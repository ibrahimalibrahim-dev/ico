import jenkins.model.*
import hudson.model.*
import hudson.security.*

def usernames = ["alice","bob","charlie"] // <-- populate known usernames

def jenkins = Jenkins.instance
def auth = jenkins.getAuthorizationStrategy()

def globalCsv = new File("/tmp/users_vs_permissions.csv")
def pipelinesCsv = new File("/tmp/users_vs_pipelines.csv")

def globalPerms = ["OverallRead": Permission.fromId("Overall/Read"),
                   "Administer": Permission.fromId("Overall/Administer")]

def rows = usernames.collect { userId ->
    def row = [userId]
    globalPerms.each { name, perm ->
        row << (auth.hasPermission(userId, perm) ? "✔" : "")
    }
    row
}

globalCsv.text = [["User/Group"] + globalPerms.keySet()].join(",") + "\n" +
                  rows.collect { it.join(",") }.join("\n")
println "✅ Users vs Global permissions CSV written: ${globalCsv.path}"

// Pipelines
def pipelines = jenkins.getAllItems(Job.class).sort { it.fullName }
def header = ["User/Group"] + pipelines.collect { it.fullName }
def pipelineRows = usernames.collect { userId ->
    def row = [userId]
    pipelines.each { job ->
        def allowed = auth.hasPermission(userId, Item.READ) ||
                      auth.hasPermission(userId, Item.BUILD) ||
                      auth.hasPermission(userId, Item.CONFIGURE) ||
                      auth.hasPermission(userId, Item.DELETE)
        row << (allowed ? "✔" : "")
    }
    row
}

pipelinesCsv.text = [header.join(","), pipelineRows.collect { it.join(",") }.join("\n")].join("\n")
println "✅ Users vs Pipelines CSV written: ${pipelinesCsv.path}"
