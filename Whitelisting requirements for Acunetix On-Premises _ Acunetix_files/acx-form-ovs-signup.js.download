//
// Client side validation for Sign up form
//
jQuery(function($) {
    'use strict';

    (function() {
	// overwrite email validation to disallow '+' in username
        $.validator.methods.email = function(a, b) {return this.optional(b)||/^[a-zA-Z0-9.!#$%&'*\/=?^_`{|}~-]+@[a-zA-Z0-9](?:[a-zA-Z0-9-]{0,61}[a-zA-Z0-9])?(?:\.[a-zA-Z0-9](?:[a-zA-Z0-9-]{0,61}[a-zA-Z0-9])?)*$/.test(a)}

	//
        // Extend jquery.validate
        //
        function patternValidation(value, element, params) {
            return this.optional(element) || params.test(value);
        }

	function isValidPhoneNumber(phoneNumber) {

	  if(typeof(window.libphonenumber) === 'undefined') {
	    return false;
	  }
          return libphonenumber.isValidNumber(phoneNumber)
        }

        $.validator.addMethod('pattern', patternValidation, 'Please check this value.');
	$.validator.addMethod('validPhone', isValidPhoneNumber, 'Please enter a valid phone number.');
    })();

    function computePasswordHash(password) {
        var sha256 = function(value) { return CryptoJS.SHA256(value).toString(); };
        return sha256(password);
    }

    //
    // OVS Registration Form
    //
    $.widget('ui.signupOVS2', {

        _create: function() {
            this.element.validate({
                submitHandler: function(form) {
                    var $form = $(form);

                    // Check if ReCaptcha was filled (uses :blank selector added by jquery.validate plugin)
                    if ($form.find('#recaptcha_response_field').length > 0 && $form.find('#recaptcha_response_field').is(':blank')) {
                        alert('CAPTCHA is required.');
                        return false;
                    }

                    var $passField = $('#register-password');
                    if ($passField.is(':filled')) {
                        var passwordHash = computePasswordHash($passField.val());

                        $('#register-password-hash').val(passwordHash);
                        $('#register-password,#register-retype-password').val('');
                    }
                    else {
                        $('#register-password-hash').val('');
                    }

                    form.submit();

                    return false;
                },

                rules: {
                    '__ovs[email]': {
                        required: true,
                        email: true
                    },
                    '__ovs[password]': {
                        required: true,
                        pattern: /(?=^[^\s]{8,}$)((?=.*?\d)(?=.*?[A-Z])(?=.*?[a-z])|(?=.*?\d)(?=.*?[^\w\d\s])(?=.*?[a-z])|(?=.*?[^\w\d\s])(?=.*?[A-Z])(?=.*?[a-z])|(?=.*?\d)(?=.*?[A-Z])(?=.*?[^\w\d\s]))^.*/
                    },
                    '__ovs[retype-password]': {
                        required: true,
                        equalTo: '#register-password'
                    },
                    '__ovs[name]': {
                        required: true,
                        minlength: 3,
                        maxlength: 64
                    },
                    '__ovs[surname]': {
                        required: true,
                        minlength: 3,
                        maxlength: 64
                    },
		    '__ovs[phone]': {
			validPhone: true
		    }
                },
                messages: {
                    '__ovs[password]': {
                        pattern: 'Password does not meet the password policy.'
                    },
                    '__ovs[retype-password]': {
                        equalTo: 'Passwords do not match.'
                    },
                    '__ovs[phone]': {
			validPhone: 'Please enter a valid phone number.'
		    }
                }
            });
        }
    });
    $('#signup-form2').signupOVS2();
});
