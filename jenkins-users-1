import groovy.json.JsonOutput
import jenkins.model.Jenkins
import com.michelin.cio.hudson.plugins.rolestrategy.*

def strategy = Jenkins.instance.authorizationStrategy

if (!(strategy instanceof RoleBasedAuthorizationStrategy)) {
    println JsonOutput.toJson([error: "Not using Role Strategy Plugin"])
    return
}

def results = []

def roleTypes = ["globalRoles", "projectRoles", "slaveRoles"]

roleTypes.each { type ->
    def roleMap = strategy.getGrantedRoles(type)
    if (!roleMap) return

    roleMap.each { role, sids ->

        def permissions = role.permissions.collect { it.id }

        results << [
            role: role.name,
            type: type,
            pattern: role.hasProperty("pattern") ? role.pattern : null,
            permissions: permissions,
            sids: sids as List
        ]
    }
}

println JsonOutput.prettyPrint(JsonOutput.toJson(results))
